rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email in ['dojojin@gmail.com'];
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'msg', 'ts'])
        && request.resource.data.name is string
        && request.resource.data.msg is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.msg.size() > 0
        && request.resource.data.msg.size() <= 300;
      allow update: if false;
      allow delete: if isOwner();
    }

    match /meta/visitors {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count is int
        && request.resource.data.count >= 0;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
